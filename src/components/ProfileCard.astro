---
import type { ImageMetadata } from 'astro';
import { Image } from 'astro:assets';

interface Props {
    title: string;
    description: string;
    image: {
        src: ImageMetadata;
        alt: string;
    }
}

const { title, description, image } = Astro.props;
---

<div class="card">
    <h3>{title}</h3>
    <Image src={image.src} alt={image.alt} width={320} height={200}/>
    <div class="card-content">
        <p>{description}</p>
    </div>
</div>

<style>
    .card {
        background-color: white;
        padding: 10px;
        border-radius: 1rem;
        box-shadow:
            0 10px 15px -3px rgba(0, 0, 0, 0.1),
            0 4px 6px -2px rgba(0, 0, 0, 0.05);
        overflow: hidden;
        max-width: 320px;
    }

    .card img{
        width: 100%;
        height: 200px;
        object-fit: cover;
    }

    h3{
        margin-top: 0;
        font-size: 1.5rem;
        text-align: left;
    }
</style>
