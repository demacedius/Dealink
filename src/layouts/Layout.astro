---
import Header from '../components/Header.astro'
import '../../src/styles/global.css'
interface Props{
    title:string
}

const { title } = Astro.props
---

<html lang="en">
    <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width" />
        <meta name="generator" content={Astro.generator} />
        <title>{title}</title>
        
    </head>
    <body>
        <Header />
        <slot />
    </body>
</html>